@page "/"

<PageTitle>Home</PageTitle>

<div class="home-page py-4">
	<h1 class="mb-3">blazor wasm graph</h1>

	<p class="text-secondary mb-4">
		This task adds a sales chart page that is loaded from a lazy assembly.
	</p>

	<div class="card shadow-sm border-0">
		<div class="card-body">
			<h3 class="h5 mb-3">what is inside</h3>

